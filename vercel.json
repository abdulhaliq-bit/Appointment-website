{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/book",
      "dest": "/api/book.js"
    },
    {
      "src": "/api/slots",
      "dest": "/api/slots.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
